---
import ContentLayout from "../../layouts/ContentLayout.astro";

// Sample hierarchical notes structure
const notesStructure = {
  areas: [
    {
      id: "programming",
      title: "Programming",
      projects: [
        {
          id: "web-dev",
          title: "Web Development",
          notes: [
            { id: "react-hooks", title: "React Hooks Deep Dive", backlinks: ["js-async", "state-management"] },
            { id: "js-async", title: "JavaScript Async Patterns", backlinks: ["react-hooks", "node-streams"] },
            { id: "css-grid", title: "CSS Grid Mastery", backlinks: ["responsive-design"] }
          ]
        },
        {
          id: "backend",
          title: "Backend Development", 
          notes: [
            { id: "node-streams", title: "Node.js Streams", backlinks: ["js-async", "database-optimization"] },
            { id: "database-optimization", title: "Database Query Optimization", backlinks: ["node-streams"] }
          ]
        }
      ]
    },
    {
      id: "design",
      title: "Design",
      projects: [
        {
          id: "ui-ux",
          title: "UI/UX Design",
          notes: [
            { id: "design-systems", title: "Design System Principles", backlinks: ["component-library"] },
            { id: "responsive-design", title: "Responsive Design Patterns", backlinks: ["css-grid", "mobile-first"] },
            { id: "component-library", title: "Building Component Libraries", backlinks: ["design-systems"] }
          ]
        }
      ]
    },
    {
      id: "personal",
      title: "Personal",
      projects: [
        {
          id: "productivity", 
          title: "Productivity",
          notes: [
            { id: "morning-routine", title: "Morning Routine Ideas", backlinks: ["time-management"] },
            { id: "time-management", title: "Time Management Strategies", backlinks: ["morning-routine", "deep-work"] },
            { id: "deep-work", title: "Deep Work Principles", backlinks: ["time-management"] }
          ]
        }
      ]
    }
  ]
};

// Sample note content
const sampleNote = {
  id: "react-hooks",
  title: "React Hooks Deep Dive",
  content: `# React Hooks Deep Dive

React Hooks revolutionized how we write components by allowing us to use state and lifecycle methods in functional components.

## Key Concepts

### useState Hook
The \`useState\` hook allows you to add state to functional components:

\`\`\`javascript
const [count, setCount] = useState(0);
\`\`\`

### useEffect Hook
The \`useEffect\` hook lets you perform side effects in function components:

\`\`\`javascript
useEffect(() => {
  document.title = \`Count: \${count}\`;
}, [count]);
\`\`\`

## Related Notes
- [[JavaScript Async Patterns]] - Understanding async patterns helps with useEffect
- [[State Management]] - Hooks are fundamental to modern state management

## Best Practices
1. Always include dependencies in useEffect dependency array
2. Use custom hooks to share stateful logic
3. Keep hooks at the top level of components`,
  area: "Programming",
  project: "Web Development",
  lastModified: "2024-01-15",
  tags: ["react", "hooks", "javascript"]
};
---

<ContentLayout title="Notes">
  <div class="flex h-[calc(100vh-8rem)]">
    <!-- Dynamic Sidebar -->
    <div class="w-80 bg-base-100 border-r border-base-300 flex flex-col" id="sidebar">
      <!-- Navigation Header -->
      <div class="p-4 border-b border-base-300">
        <h2 class="text-lg font-bold">Knowledge Base</h2>
        <div class="breadcrumbs text-sm mt-2" id="breadcrumbs">
          <ul>
            <li><a class="link link-hover" onclick="showOverview()">Overview</a></li>
          </ul>
        </div>
      </div>

      <!-- Sidebar Content -->
      <div class="flex-1 overflow-y-auto">
        <!-- Overview Mode (default) -->
        <div id="overview-content" class="p-4">
          <div class="mb-6">
            <input type="text" placeholder="Search notes..." class="input input-sm input-bordered w-full" />
          </div>
          
          {notesStructure.areas.map((area) => (
            <div class="mb-6">
              <h3 class="text-sm font-semibold text-primary mb-2 flex items-center">
                <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                {area.title}
              </h3>
              
              {area.projects.map((project) => (
                <div class="ml-4 mb-3">
                  <h4 class="text-sm font-medium text-base-content/80 mb-1 flex items-center cursor-pointer hover:text-primary transition-colors"
                      onclick={`showProject('${area.id}', '${project.id}')`}>
                    <svg class="w-3 h-3 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    {project.title}
                  </h4>
                  
                  <div class="ml-5 space-y-1">
                    {project.notes.map((note) => (
                      <div class="text-xs text-base-content/70 hover:text-primary cursor-pointer py-1 transition-colors"
                           onclick={`showNote('${note.id}', '${area.title}', '${project.title}')`}>
                        • {note.title}
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          ))}
        </div>

        <!-- Note Mode (when viewing a specific note) -->
        <div id="note-content" class="p-4 hidden">
          <!-- Back Navigation -->
          <button class="btn btn-ghost btn-sm mb-4" onclick="goBack()">
            <svg class="w-4 h-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back
          </button>

          <!-- Current Note Info -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-primary mb-2">Current Note</h3>
            <div class="bg-base-200 rounded-lg p-3">
              <div class="text-sm font-medium" id="current-note-title">React Hooks Deep Dive</div>
              <div class="text-xs text-base-content/60" id="current-note-path">Programming → Web Development</div>
            </div>
          </div>

          <!-- Backlinks -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-base-content/80 mb-2 flex items-center">
              <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.102m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
              Backlinks
              <span class="badge badge-xs badge-primary ml-2" id="backlinks-count">2</span>
            </h3>
            <div class="space-y-2" id="backlinks-list">
              <div class="text-sm text-base-content/70 hover:text-primary cursor-pointer py-1 px-2 hover:bg-base-200 rounded transition-colors"
                   onclick="showNote('js-async', 'Programming', 'Web Development')">
                JavaScript Async Patterns
              </div>
              <div class="text-sm text-base-content/70 hover:text-primary cursor-pointer py-1 px-2 hover:bg-base-200 rounded transition-colors"
                   onclick="showNote('state-management', 'Programming', 'Web Development')">
                State Management Strategies
              </div>
            </div>
          </div>

          <!-- Outbound Links -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-base-content/80 mb-2 flex items-center">
              <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Links in this note
            </h3>
            <div class="space-y-1">
              <div class="text-xs text-base-content/60 hover:text-primary cursor-pointer py-1 transition-colors"
                   onclick="showNote('js-async', 'Programming', 'Web Development')">
                → JavaScript Async Patterns
              </div>
              <div class="text-xs text-base-content/60 hover:text-primary cursor-pointer py-1 transition-colors"
                   onclick="showNote('state-management', 'Programming', 'Web Development')">
                → State Management
              </div>
            </div>
          </div>

          <!-- Quick Actions -->
          <div>
            <h3 class="text-sm font-semibold text-base-content/80 mb-2">Quick Actions</h3>
            <div class="space-y-2">
              <button class="btn btn-ghost btn-xs w-full justify-start">
                <svg class="w-3 h-3 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Edit Note
              </button>
              <button class="btn btn-ghost btn-xs w-full justify-start">
                <svg class="w-3 h-3 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z" />
                </svg>
                Share
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content Area -->
    <div class="flex-1 bg-base-50 overflow-y-auto">
      <div class="max-w-4xl mx-auto p-8">
        <!-- Welcome State -->
        <div id="welcome-content">
          <div class="text-center py-16">
            <div class="text-6xl mb-6">📚</div>
            <h1 class="text-4xl font-bold mb-4">Knowledge Base</h1>
            <p class="text-xl text-base-content/70 mb-8">
              Explore your notes by browsing areas and projects in the sidebar, or search for specific topics.
            </p>
            <div class="stats shadow">
              <div class="stat">
                <div class="stat-title">Total Notes</div>
                <div class="stat-value text-primary">12</div>
              </div>
              <div class="stat">
                <div class="stat-title">Areas</div>
                <div class="stat-value text-secondary">3</div>
              </div>
              <div class="stat">
                <div class="stat-title">Projects</div>
                <div class="stat-value text-accent">5</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Note Content -->
        <div id="main-content" class="hidden">
          <div class="prose prose-lg max-w-none">
            <div class="flex justify-between items-start mb-8">
              <div>
                <h1 id="note-title">React Hooks Deep Dive</h1>
                <div class="flex gap-4 text-sm text-base-content/60 not-prose">
                  <span id="note-area">Programming</span>
                  <span>•</span>
                  <span id="note-project">Web Development</span>
                  <span>•</span>
                  <span id="note-date">Last updated Jan 15, 2024</span>
                </div>
              </div>
              <div class="flex gap-2 not-prose">
                <button class="btn btn-ghost btn-sm">
                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                </button>
                <button class="btn btn-ghost btn-sm">
                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z" />
                  </svg>
                </button>
              </div>
            </div>
            
            <!-- Note content would be rendered here from markdown -->
            <div id="note-content-body">
              <p>React Hooks revolutionized how we write components by allowing us to use state and lifecycle methods in functional components.</p>
              
              <h2>Key Concepts</h2>
              
              <h3>useState Hook</h3>
              <p>The <code>useState</code> hook allows you to add state to functional components:</p>
              
              <pre><code>const [count, setCount] = useState(0);</code></pre>
              
              <h3>useEffect Hook</h3>
              <p>The <code>useEffect</code> hook lets you perform side effects in function components:</p>
              
              <pre><code>{`useEffect(() => {
  document.title = \`Count: \${count}\`;
}, [count]);`}</code></pre>
              
              <h2>Related Notes</h2>
              <ul>
                <li><a href="#" class="link link-primary" onclick="showNote('js-async', 'Programming', 'Web Development')">JavaScript Async Patterns</a> - Understanding async patterns helps with useEffect</li>
                <li><a href="#" class="link link-primary" onclick="showNote('state-management', 'Programming', 'Web Development')">State Management</a> - Hooks are fundamental to modern state management</li>
              </ul>
              
              <h2>Best Practices</h2>
              <ol>
                <li>Always include dependencies in useEffect dependency array</li>
                <li>Use custom hooks to share stateful logic</li>
                <li>Keep hooks at the top level of components</li>
              </ol>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ notesStructure }}>
    let currentView = 'overview';
    let previousView = null;
    let navigationHistory = [];

    function showOverview() {
      currentView = 'overview';
      document.getElementById('overview-content').classList.remove('hidden');
      document.getElementById('note-content').classList.add('hidden');
      document.getElementById('welcome-content').classList.remove('hidden');
      document.getElementById('main-content').classList.add('hidden');
      
      // Update breadcrumbs
      document.getElementById('breadcrumbs').innerHTML = `
        <ul>
          <li><a class="link link-hover">Overview</a></li>
        </ul>
      `;
    }

    function showProject(areaId, projectId) {
      // Could expand to show project overview
      console.log(`Showing project: ${areaId}/${projectId}`);
    }

    function showNote(noteId, areaTitle, projectTitle) {
      // Save current state to history
      navigationHistory.push(currentView);
      
      currentView = 'note';
      
      // Update sidebar
      document.getElementById('overview-content').classList.add('hidden');
      document.getElementById('note-content').classList.remove('hidden');
      
      // Update main content
      document.getElementById('welcome-content').classList.add('hidden');
      document.getElementById('main-content').classList.remove('hidden');
      
      // Update breadcrumbs
      document.getElementById('breadcrumbs').innerHTML = `
        <ul>
          <li><a class="link link-hover" onclick="showOverview()">Overview</a></li>
          <li><a class="link link-hover">${areaTitle}</a></li>
          <li><a class="link link-hover">${projectTitle}</a></li>
          <li>Current Note</li>
        </ul>
      `;
      
      // Update note info in sidebar
      document.getElementById('current-note-title').textContent = getNoteTitle(noteId);
      document.getElementById('current-note-path').textContent = `${areaTitle} → ${projectTitle}`;
      
      // Update main content
      document.getElementById('note-title').textContent = getNoteTitle(noteId);
      document.getElementById('note-area').textContent = areaTitle;
      document.getElementById('note-project').textContent = projectTitle;
      
      // Update backlinks (mock data for demo)
      updateBacklinks(noteId);
    }

    function goBack() {
      if (navigationHistory.length > 0) {
        const previousView = navigationHistory.pop();
        if (previousView === 'overview') {
          showOverview();
        }
      } else {
        showOverview();
      }
    }

    function getNoteTitle(noteId) {
      // Find note title from structure
      for (const area of notesStructure.areas) {
        for (const project of area.projects) {
          const note = project.notes.find(n => n.id === noteId);
          if (note) return note.title;
        }
      }
      return 'Unknown Note';
    }

    function updateBacklinks(noteId) {
      // Find backlinks for this note
      const backlinks = [];
      for (const area of notesStructure.areas) {
        for (const project of area.projects) {
          for (const note of project.notes) {
            if (note.backlinks && note.backlinks.includes(noteId)) {
              backlinks.push({
                id: note.id,
                title: note.title,
                area: area.title,
                project: project.title
              });
            }
          }
        }
      }
      
      // Update backlinks count and list
      document.getElementById('backlinks-count').textContent = backlinks.length;
      const backlinksHtml = backlinks.map(link => `
        <div class="text-sm text-base-content/70 hover:text-primary cursor-pointer py-1 px-2 hover:bg-base-200 rounded transition-colors"
             onclick="showNote('${link.id}', '${link.area}', '${link.project}')">
          ${link.title}
        </div>
      `).join('');
      
      document.getElementById('backlinks-list').innerHTML = backlinksHtml;
    }

    // Initialize
    showOverview();
  </script>
</ContentLayout>
