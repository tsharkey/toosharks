---
interface Props {}
---

<div class="under-construction">
  <div class="container">
    <h1>Coming Soon</h1>
    <p>This page is currently under construction. Please check back later.</p>
  </div>
</div>

<style>
  .under-construction {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 1rem;
    text-align: center;
  }

  .container {
    max-width: 600px;
    width: 100%;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: bold;
    margin-bottom: 1rem;
    color: #333;
  }

  p {
    font-size: clamp(1rem, 3vw, 1.25rem);
    color: #666;
    line-height: 1.6;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .under-construction {
      padding: 2rem 1rem;
    }
    
    .container {
      max-width: 100%;
    }
  }
</style>

